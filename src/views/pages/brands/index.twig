{% extends "layouts/master.twig" %}
{% block title %}{{ 'الماركات' | trans }} | {{ store.name }}{% endblock %}
{% block content %}
<div class="page-brands">
    <div class="container">
        <div class="page-header page-header--simple"><h1>{{ 'الماركات' | trans }}</h1></div>
        {% if brands | length > 0 %}
        <div class="brands-grid">
            {% for brand in brands %}
            <a href="{{ brand.url }}" class="brand-card">
                {% if brand.logo %}<img src="{{ brand.logo }}" alt="{{ brand.name }}">{% endif %}
                <h3>{{ brand.name }}</h3>
            </a>
            {% endfor %}
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}
